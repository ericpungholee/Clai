FAL_KEY=your_fal_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
REDIS_URL=redis://localhost:6379/0

# Optional overrides
# Gemini Image Generation - Single model for both create and edit workflows
# GEMINI_FLASH_MODEL=gemini-3.1-flash-image-preview
# GEMINI_PRO_MODEL=gemini-3.1-flash-image-preview  # Backward-compatible alias
# GEMINI_THINKING_LEVEL=low  # Retained for compatibility; ignored by image generation
# GEMINI_IMAGE_SIZE=1K  # Image resolution hint
# GEMINI_IMAGE_ASPECT_RATIO=1:1

# Artifact Storage (Test/Debug Mode)
# SAVE_ARTIFACTS_LOCALLY=false  # Set to true to save all artifacts to backend/tests/artifacts/
#                                # Saves: Gemini images, GLB models, videos, no-bg images, state.json
#                                # Useful for testing and debugging

# Trellis
# TRELLIS_MODEL_ID=fal-ai/trellis-2
# TRELLIS_PRODUCT_QUALITY=balanced_plus  # Product pipeline default: fast | balanced | balanced_plus | high_quality
